# ═══════════════════════════════════════════════════════════
# ОБЯЗАТЕЛЬНЫЕ (без них backend не запустится корректно)
# ═══════════════════════════════════════════════════════════

# Mantle mainnet RPC — бесплатный публичный endpoint
MANTLE_RPC_URL=https://rpc.mantle.xyz

# Mantle Sepolia (для on-chain записи сигналов через контракты)
MANTLE_CONTRACT_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003

# Приватный ключ для on-chain записи (Sepolia только, без реальных денег)
# Получи тестовый кошелёк: https://faucet.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=

# ═══════════════════════════════════════════════════════════
# AI ПРОВАЙДЕРЫ (нужен хотя бы один)
# ═══════════════════════════════════════════════════════════

# OpenAI — основной. Получи: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq — быстрый fallback. Получи: https://console.groq.com
GROQ_API_KEY=

# AltLLM — crypto-native AI. Получи: https://altllm.ai
ALTLLM_API_KEY=

# ═══════════════════════════════════════════════════════════
# TELEGRAM (опционально, но рекомендуется для демо)
# ═══════════════════════════════════════════════════════════

# Создай бота: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Имя бота (узнать: напиши @get_me_bot или @BotFather → /mybots → твой бот → API)
# Если не указать — фронтенд покажет "dorahacksmantle_bot"
TELEGRAM_BOT_USERNAME=

# Твой Telegram chat_id. Узнай: https://t.me/userinfobot
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════
# JWT (ОБЯЗАТЕЛЬНО для auth)
# ═══════════════════════════════════════════════════════════

# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ═══════════════════════════════════════════════════════════
# КОНТРАКТЫ (заполни после деплоя)
# ═══════════════════════════════════════════════════════════

# Адрес AgentIdentity контракта на Sepolia
AGENT_CONTRACT_ADDRESS=

# ═══════════════════════════════════════════════════════════
# РЕЖИМ РАБОТЫ
# ═══════════════════════════════════════════════════════════

DEMO_MODE=true
