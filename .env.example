# Mantle Network
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
# Not used — users connect their own wallet via Telegram
MANTLE_PRIVATE_KEY=

# JWT secret for SIWE auth tokens (leave empty to auto-generate per process)
JWT_SECRET=

# Telegram Bot (optional — disabled if empty)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Providers (at least one required)
OPENAI_API_KEY=
GROQ_API_KEY=
ALTLLM_API_KEY=

# Optional: Nansen / Elfa AI
NANSEN_API_KEY=
ELFA_AI_API_KEY=

# Agent contract (fill after deployment)
AGENT_CONTRACT_ADDRESS=

# App mode
DEMO_MODE=true
